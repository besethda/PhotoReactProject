{
  "name": "noominord-monorepo",
  "workspaces": [
    "frontend",
    "api"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:frontend\" \"bun run dev:api\"",
    "dev:frontend": "bun --cwd frontend dev",
    "dev:api": "bun --cwd api dev"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1"
  }
}